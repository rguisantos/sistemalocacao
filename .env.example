# ============================
# DATABASE
# ============================
DATABASE_URL="postgresql://locacoes:locacoes@localhost:5432/locacoes_db"

# ============================
# JWT
# ============================
JWT_ACCESS_SECRET="sua-chave-secreta-de-acesso-muito-longa-e-segura"
JWT_REFRESH_SECRET="sua-chave-secreta-de-refresh-muito-longa-e-segura"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================
# API
# ============================
PORT=3001
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,exp://192.168.1.100:8081"

# ============================
# REDIS (para rate limiting)
# ============================
REDIS_URL="redis://localhost:6379"

# ============================
# MERCADO PAGO
# ============================
MERCADOPAGO_ACCESS_TOKEN="seu-access-token-aqui"
MERCADOPAGO_WEBHOOK_SECRET="seu-webhook-secret"
MERCADOPAGO_NOTIFICATION_URL="https://seu-dominio.com/api/pagamentos/webhook"

# ============================
# WEB (Next.js)
# ============================
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXTAUTH_SECRET="sua-chave-nextauth"
NEXTAUTH_URL="http://localhost:3000"

# ============================
# MOBILE (Expo)
# ============================
EXPO_PUBLIC_API_URL="http://192.168.1.100:3001"
