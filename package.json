{
  "name": "locacoes-sistema",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:seed": "npm run db:seed -w @locacoes/database",
    "db:seed:demo": "npm run db:seed:demo -w @locacoes/database"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "react-native": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    },
    "react-native-reanimated": {
      "react": "18.3.1"
    },
    "react-native-gesture-handler": {
      "react": "18.3.1"
    },
    "react-native-screens": {
      "react": "18.3.1"
    },
    "react-native-safe-area-context": {
      "react": "18.3.1"
    },
    "expo-router": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    },
    "@react-navigation/core": {
      "react": "18.3.1"
    },
    "@react-navigation/native": {
      "react": "18.3.1"
    },
    "react-helmet-async": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}