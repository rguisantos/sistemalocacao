impressora.ts: o sentinela 'undefined = ainda não tentou' vive num let
de escopo de módulo, e o TS não estreita esse tipo após o try/catch
(closures podem mutá-lo) — o return final ainda carregava | undefined.
Resolvido com ?? null, preservando o cache de carregamento da lib.
---
 apps/mobile/src/services/impressora.ts | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/apps/mobile/src/services/impressora.ts b/apps/mobile/src/services/impressora.ts
index b40fcbe..1afa831 100644
--- a/apps/mobile/src/services/impressora.ts
+++ b/apps/mobile/src/services/impressora.ts
@@ -31,7 +31,8 @@ function carregarModulo(): ModuloBluetooth | null {
   } catch {
     modulo = null; // lib não instalada (Expo Go / build sem o módulo)
   }
-  return modulo;
+  // ?? null: o TS não estreita `let` de escopo de módulo após o try/catch
+  return modulo ?? null;
 }
 
 let enderecoImpressora: string | null = null;
