{
  "expo": {
    "name": "Locações",
    "slug": "locacoes-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "locacoes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1b5e3f"
    },
    "android": {
      "package": "br.com.locacoes.app",
      "permissions": [
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "br.com.locacoes.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localização para preencher o endereço do cliente."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3433f34b-e706-4704-8711-2fb8b42d4651"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "rguisantoss",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/3433f34b-e706-4704-8711-2fb8b42d4651"
    }
  }
}
